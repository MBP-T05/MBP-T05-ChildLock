* text=auto

# Keep source and docs in LF for stable diffs across environments.
*.c text eol=lf
*.h text eol=lf
*.cpp text eol=lf
*.hpp text eol=lf
*.md text eol=lf
*.txt text eol=lf
*.cmake text eol=lf
CMakeLists.txt text eol=lf
*.yml text eol=lf
*.yaml text eol=lf

# Windows command scripts should remain CRLF.
*.bat text eol=crlf
*.cmd text eol=crlf
